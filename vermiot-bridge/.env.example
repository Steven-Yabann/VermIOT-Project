# Firebase configuration
# Get DATABASE_URL from: Firebase Console → Realtime Database → copy the URL
DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# MQTT broker (default: HiveMQ public broker — no auth required)
MQTT_BROKER=mqtt://broker.hivemq.com:1883
MQTT_CLIENT_ID=VermIoT_Bridge_Group4E

# Bed identifier — matches the Firebase path beds/{BED_ID}/
BED_ID=bed_1
